{
  "name": "@pi-plugins/subagent",
  "version": "0.1.2",
  "description": "Minimal subagent tool extension for pi-agent: delegate a task to a fresh headless pi instance.",
  "keywords": [
    "pi",
    "pi-agent",
    "pi-extension",
    "pi-package",
    "subagent"
  ],
  "homepage": "https://github.com/k3dom/pi-plugins/tree/main/plugins/subagent#readme",
  "bugs": {
    "url": "https://github.com/k3dom/pi-plugins/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k3dom/pi-plugins.git",
    "directory": "plugins/subagent"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "pnpm run build",
    "build": "tsdown",
    "check": "pnpm run lint && pnpm run check-types && pnpm run format:check",
    "check-types": "tsc -b",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.93",
    "effect": "4.0.0-beta.93"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.3",
    "@earendil-works/pi-tui": "0.80.3",
    "@pi-plugins/fmt": "workspace:*",
    "@pi-plugins/lint": "workspace:*",
    "@pi-plugins/shared": "workspace:*",
    "@pi-plugins/tsconfig": "workspace:*",
    "@types/node": "26.1.0",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "tsdown": "0.22.3",
    "typebox": "1.1.38",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./dist/index.mjs"
    ]
  }
}
