{
  "name": "@pi-plugins/lint",
  "version": "0.0.0",
  "private": true,
  "description": "Shared oxlint linter configuration for pi-plugins.",
  "files": [
    "index.ts"
  ],
  "type": "module",
  "exports": {
    ".": "./index.ts"
  },
  "scripts": {
    "check": "pnpm run check-types && pnpm run format:check",
    "check-types": "tsc -b",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "@pi-plugins/fmt": "workspace:*",
    "@pi-plugins/tsconfig": "workspace:*",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "oxlint": "*"
  }
}
