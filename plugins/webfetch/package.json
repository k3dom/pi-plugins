{
  "name": "@pi-plugins/webfetch",
  "version": "0.2.0",
  "description": "WebFetch tool extension for pi-agent.",
  "keywords": [
    "pi",
    "pi-agent",
    "pi-extension",
    "pi-package",
    "webfetch"
  ],
  "homepage": "https://github.com/k3dom/pi-plugins/tree/main/plugins/webfetch#readme",
  "bugs": {
    "url": "https://github.com/k3dom/pi-plugins/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k3dom/pi-plugins.git",
    "directory": "plugins/webfetch"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "pnpm run build",
    "build": "tsdown",
    "check-types": "tsc -b",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "defuddle": "0.18.1",
    "effect": "4.0.0-beta.70",
    "linkedom": "0.18.12",
    "turndown": "7.2.4"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.75.4",
    "@earendil-works/pi-coding-agent": "0.75.4",
    "@earendil-works/pi-tui": "0.75.4",
    "@pi-plugins/fmt": "workspace:*",
    "@pi-plugins/lint": "workspace:*",
    "@pi-plugins/shared": "workspace:*",
    "@pi-plugins/tsconfig": "workspace:*",
    "@types/node": "25.9.1",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "tsdown": "0.22.0",
    "typebox": "1.1.38",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./dist/index.mjs"
    ]
  }
}
