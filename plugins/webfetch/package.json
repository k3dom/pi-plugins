{
  "name": "@pi-plugins/webfetch",
  "version": "0.0.0",
  "private": true,
  "description": "WebFetch tool extension for pi-agent.",
  "keywords": [
    "pi",
    "pi-agent",
    "pi-extension",
    "pi-package",
    "webfetch"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@pi-plugins/shared": "workspace:*",
    "defuddle": "^0.18.1",
    "effect": "4.0.0-beta.70",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.75.5",
    "@earendil-works/pi-coding-agent": "0.75.3",
    "@earendil-works/pi-tui": "0.75.5",
    "@pi-plugins/fmt": "workspace:*",
    "@pi-plugins/lint": "workspace:*",
    "@pi-plugins/tsconfig": "workspace:*",
    "@types/node": "^25.9.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tsdown": "^0.22.0",
    "typebox": "^1.1.38",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./dist/index.mjs"
    ]
  }
}
