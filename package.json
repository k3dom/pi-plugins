{
  "name": "pi-plugins",
  "private": true,
  "workspaces": [
    "plugins/*",
    "tooling/*"
  ],
  "type": "module",
  "scripts": {
    "format": "oxfmt --disable-nested-config",
    "format:check": "oxfmt --disable-nested-config --check",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@pi-plugins/fmt": "workspace:*",
    "oxfmt": "0.57.0",
    "turbo": "2.10.2"
  },
  "packageManager": "pnpm@11.2.2"
}
